# ── General ────────────────────────────────────────────────────────────────
# Your server's domain name (used in Prometheus/Alertmanager external URLs
# and Grafana root URL). Use "localhost" for local development.
DOMAIN=localhost

# IANA timezone string — controls timestamps across all services.
TZ=UTC

# ── Ports ──────────────────────────────────────────────────────────────────
# Ports exposed on the host by the Nginx reverse proxy.
HTTP_PORT=80
HTTPS_PORT=443

# ── Grafana ─────────────────────────────────────────────────────────────────
# Admin credentials for the Grafana UI. Change these before first start.
# After first login you can add additional users through the UI.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_now

# ── Prometheus ──────────────────────────────────────────────────────────────
# How long to keep metrics data (time-based or size-based, whichever hits first).
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ── Alertmanager – Email receiver ───────────────────────────────────────────
# Leave SMTP_HOST blank to disable email alerts.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=your_smtp_password
ALERT_EMAIL_TO=oncall@example.com

# ── Alertmanager – Slack receiver ───────────────────────────────────────────
# Create an incoming-webhook in your Slack workspace and paste the URL below.
# Leave blank to disable Slack alerts.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
SLACK_CHANNEL=#monitoring-alerts

# ── Environment label ───────────────────────────────────────────────────────
# Attached to every metric and alert so you can distinguish staging from prod.
ENVIRONMENT=production
